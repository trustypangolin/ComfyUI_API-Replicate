            "components": {
                "schemas": {
                    "Input": {
                        "type": "object",
                        "title": "Input",
                        "required": [
                            "media"
                        ],
                        "properties": {
                            "fps": {
                                "type": "integer",
                                "title": "Fps",
                                "default": 24,
                                "maximum": 120,
                                "minimum": 1,
                                "x-order": 4,
                                "description": "Frames-per-second for video outputs."
                            },
                            "seed": {
                                "type": "integer",
                                "title": "Seed",
                                "x-order": 5,
                                "nullable": true,
                                "description": "Random seed. Leave blank for a random seed each call."
                            },
                            "media": {
                                "type": "string",
                                "title": "Media",
                                "format": "uri",
                                "x-order": 0,
                                "description": "Video (mp4/mov) or image (png/jpg/webp) to restore."
                            },
                            "sp_size": {
                                "type": "integer",
                                "title": "Sp Size",
                                "default": 1,
                                "maximum": 4,
                                "minimum": 1,
                                "x-order": 3,
                                "description": "Sequence-parallel shard heuristic (single-GPU build only accepts 1)."
                            },
                            "cfg_scale": {
                                "type": "number",
                                "title": "Cfg Scale",
                                "default": 1,
                                "maximum": 15,
                                "minimum": 0,
                                "x-order": 1,
                                "description": "Classifier-free guidance scale (higher = stronger restoration)."
                            },
                            "resolution": {
                                "type": "integer",
                                "title": "Resolution",
                                "default": 1080,
                                "maximum": 16384,
                                "minimum": 16,
                                "x-order": 10,
                                "description": "Target resolution for the shortest edge in pixels (default: 1080).\nAutomatically maintains aspect ratio of input.\nEven values required for optimal processing."
                            },
                            "sample_steps": {
                                "type": "integer",
                                "title": "Sample Steps",
                                "default": 1,
                                "maximum": 4,
                                "minimum": 1,
                                "x-order": 2,
                                "description": "Sampling steps (1 = fast one-step mode)."
                            },
                            "model_variant": {
                                "allOf": [
                                    {
                                        "$ref": "#/components/schemas/model_variant"
                                    }
                                ],
                                "default": "7b",
                                "x-order": 9,
                                "description": "Model size to run."
                            },
                            "output_format": {
                                "allOf": [
                                    {
                                        "$ref": "#/components/schemas/output_format"
                                    }
                                ],
                                "default": "webp",
                                "x-order": 6,
                                "description": "Image output format (only used for image inputs)."
                            },
                            "max_resolution": {
                                "type": "integer",
                                "title": "Max Resolution",
                                "default": 0,
                                "maximum": 16384,
                                "minimum": 0,
                                "x-order": 11,
                                "description": "Maximum resolution limit for any dimension (default: 0, no limit).\nIf any edge exceeds this after applying resolution,\nboth dimensions are scaled down proportionally.\nUseful to prevent excessive VRAM usage on extreme aspect ratios."
                            },
                            "output_quality": {
                                "type": "integer",
                                "title": "Output Quality",
                                "default": 90,
                                "maximum": 100,
                                "minimum": 10,
                                "x-order": 7,
                                "description": "Image quality for lossy formats (jpg/webp)."
                            },
                            "apply_color_fix": {
                                "type": "boolean",
                                "title": "Apply Color Fix",
                                "default": false,
                                "x-order": 8,
                                "description": "Apply optional wavelet color correction (matches official demo)."
                            }
                        }
                    },
